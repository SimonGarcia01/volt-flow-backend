APP_NAME=Volt Flow Backend
APP_ENV=development

POSTGRES_USER=voltflow
POSTGRES_PASSWORD=voltflow_password
POSTGRES_DB=voltflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://volt_flow_user:volt_flow_password@localhost:5432/volt_flow_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
